# ══════════════════════════════════════════════════════════════
# RAGHUPATI — Single Environment File
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════

# ── Auth.js ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth → console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth → github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=          # NEVER prefix with NEXT_PUBLIC_

# ── LLM Providers (at least one required) ────────────────────
MISTRAL_API_KEY=                    # mistral.ai → API Keys
GROQ_API_KEY=                       # console.groq.com → API Keys
HUGGINGFACE_TOKEN=                  # huggingface.co/settings/tokens (Read)

# ── GitHub System Token ───────────────────────────────────────
# This is the SYSTEM token for webhooks — separate from user tokens
# User GitHub tokens are collected at login and stored in localStorage
GITHUB_TOKEN=                       # Scopes: repo, workflow, read:org
GITHUB_WEBHOOK_SECRET=              # openssl rand -hex 20

# ── CVE / Vulnerability DBs ───────────────────────────────────
NVD_API_KEY=                        # nvd.nist.gov/developers/request-an-api-key

# ── Web Research (optional) ───────────────────────────────────
TAVILY_API_KEY=                     # tavily.com → API Keys

# ── Notifications (optional) ─────────────────────────────────
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@raghupati.app

# ── Agent Model Config ────────────────────────────────────────
MODEL_RAMA=mistral-large-latest
MODEL_HANUMAN=llama-4-scout-17b-16e-instruct
MODEL_ANGADA=mixtral-8x7b-32768
MODEL_JAMBAVAN=mistral-medium-latest
MODEL_NALA=codestral-latest
MODEL_SUGREEVA=llama-4-scout-17b-16e-instruct
MODEL_VIBHISHANA=llama3-8b-8192

# ── Frontend Config ───────────────────────────────────────────
# Local dev: http://localhost:8000
# Production: set this in Vercel dashboard to your Railway/Render backend URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000

# ── Feature Flags ─────────────────────────────────────────────
NEXT_PUBLIC_AUTH_GOOGLE_AVAILABLE=0   # Set to 1 after filling AUTH_GOOGLE_ID
NEXT_PUBLIC_AUTH_GITHUB_AVAILABLE=0   # Set to 1 after filling AUTH_GITHUB_ID
